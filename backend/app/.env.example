# Environment variables for Plant Care API
# Copy this to .env and fill in your values

# Qdrant
QDRANT_URL=https://27aff9e6-8dae-4699-8803-9ee4fd06af81.eu-central-1-0.aws.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here

# OpenAI (optional - for production embeddings)
OPENAI_API_KEY=your_openai_api_key_here

# Collections (defaults should work)
PLANTS_COLLECTION=plants
PLANT_IMAGES_COLLECTION=plant-images
