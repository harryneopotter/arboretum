# Environment variables for Plant Care API
# Copy this to .env (in the same directory as this file) and fill in your values.
# The .env file is gitignored — never commit real credentials.

# Qdrant Cloud
QDRANT_URL=https://your-cluster.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here

# OpenAI (required for production-quality text search)
OPENAI_API_KEY=your_openai_api_key_here

# Collections — only override if you use different names
# PLANTS_COLLECTION=plants
# PLANT_IMAGES_COLLECTION=plant-images
