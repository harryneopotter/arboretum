# Environment variables for Plant Care API
# Copy this to .env (in the same directory as this file) and fill in your values.
# The .env file is gitignored — never commit real credentials.

# Qdrant Cloud
QDRANT_URL=https://your-cluster.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here

# Database
# Leave unset for local SQLite development.
# For Cloud Run beta hosting, set either DATABASE_URL or explicit DB_* fields.
DATABASE_URL=
DB_USER=
DB_PASS=
DB_NAME=
DB_HOST=

# OpenAI (required for production-quality text search)
OPENAI_API_KEY=your_openai_api_key_here

# Beta telemetry / admin access
# Required if you want to use /events/admin (otherwise it returns 503).
ADMIN_LOG_TOKEN=
BETA_TELEMETRY_ENABLED=true

# Collections — only override if you use different names
# PLANTS_COLLECTION=plants
# PLANT_IMAGES_COLLECTION=plant-images
